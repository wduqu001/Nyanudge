<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon manifest for Android 8.0+ (API 26+).
  References foreground + background vector layers in drawable/.
  Placed in mipmap-anydpi-v26/ so it takes priority over
  the density-specific PNG icons on capable devices.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background"/>
    <foreground android:drawable="@drawable/ic_launcher_foreground"/>
</adaptive-icon>
