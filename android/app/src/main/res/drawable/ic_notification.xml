<?xml version="1.0" encoding="utf-8"?>
<!--
  Notification icon — white silhouette of Mochi's face + clock.
  Single-color white on transparent background, as required by Android.
  Tinted by the system to match the notification shade.
  24×24dp intrinsic size (Android standard for notification icons).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:tint="@color/white">

    <!-- Left ear -->
    <path
        android:pathData="M6,9 L3.5,2.5 L9.5,6 Z"
        android:fillColor="#FFFFFF"/>

    <!-- Right ear -->
    <path
        android:pathData="M18,9 L20.5,2.5 L14.5,6 Z"
        android:fillColor="#FFFFFF"/>

    <!-- Head -->
    <path
        android:pathData="M12,3 m-8.5,0 a8.5,8.5 0 1 0 17,0 a8.5,8.5 0 1 0 -17,0"
        android:fillColor="#FFFFFF"/>

    <!-- Left eye cutout -->
    <path
        android:pathData="M9,10 m-1.4,0 a1.4,1.6 0 1 0 2.8,0 a1.4,1.6 0 1 0 -2.8,0"
        android:fillColor="#1A1512"/>

    <!-- Right eye cutout -->
    <path
        android:pathData="M15,10 m-1.4,0 a1.4,1.6 0 1 0 2.8,0 a1.4,1.6 0 1 0 -2.8,0"
        android:fillColor="#1A1512"/>

    <!-- Nose cutout -->
    <path
        android:pathData="M12,12.5 m-0.9,0 a0.9,0.7 0 1 0 1.8,0 a0.9,0.7 0 1 0 -1.8,0"
        android:fillColor="#1A1512"/>

    <!-- Clock ring (white) -->
    <path
        android:pathData="M12,19.5 m-3,0 a3,3 0 1 0 6,0 a3,3 0 1 0 -6,0"
        android:fillColor="#FFFFFF"/>

    <!-- Clock face cutout (dark) -->
    <path
        android:pathData="M12,19.5 m-2.1,0 a2.1,2.1 0 1 0 4.2,0 a2.1,2.1 0 1 0 -4.2,0"
        android:fillColor="#1A1512"/>

    <!-- Clock hands (white) -->
    <path
        android:pathData="M12,19.5 L12,17.8"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="0.6"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>
    <path
        android:pathData="M12,19.5 L13.2,20.1"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="0.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>

</vector>
