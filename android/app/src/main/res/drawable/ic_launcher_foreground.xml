<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon foreground layer.
  Canvas is 108×108dp; safe zone is the inner 72×72dp (18dp inset on each side).
  Mochi is drawn inside the safe zone so no launcher crop clips the cat.
-->
